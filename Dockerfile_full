FROM kbase/sdkpython:3.8.10
MAINTAINER KBase Developer

# Basics + build deps
RUN apt-get update && apt-get install -y --no-install-recommends \
      build-essential wget curl unzip ca-certificates tree \
  && rm -rf /var/lib/apt/lists/*

# Keep pip toolchain current; Cython helps pysam wheels fallback if needed
RUN pip install --no-cache-dir --upgrade pip setuptools wheel \
 && pip install --no-cache-dir "Cython>=0.29.0"

##### ---- Third-party binaries required by CheckM ----

# HMMER >= 3.1b1 (building 3.1b2 like before)
WORKDIR /opt
RUN curl -fsSL http://eddylab.org/software/hmmer3/3.1b2/hmmer-3.1b2-linux-intel-x86_64.tar.gz \
      -o hmmer-3.1b2-linux-intel-x86_64.tar.gz \
 && tar -xzf hmmer-3.1b2-linux-intel-x86_64.tar.gz \
 && rm -f hmmer-3.1b2-linux-intel-x86_64.tar.gz \
 && cd hmmer-3.1b2-linux-intel-x86_64 \
 && ./configure && make && make install \
 && cd easel && make check && make install

# Prodigal 2.6.3
WORKDIR /opt
RUN wget -q https://github.com/hyattpd/Prodigal/archive/v2.6.3.tar.gz \
 && tar -xzf v2.6.3.tar.gz && rm -f v2.6.3.tar.gz \
 && cd Prodigal-2.6.3 && make \
 && install -m 0755 prodigal /usr/local/bin/prodigal

# pplacer 1.1.alpha19 (includes guppy)
WORKDIR /opt
RUN wget -q https://github.com/matsen/pplacer/releases/download/v1.1.alpha19/pplacer-linux-v1.1.alpha19.zip \
 && unzip -q pplacer-linux-v1.1.alpha19.zip \
 && rm -f pplacer-linux-v1.1.alpha19.zip \
 && mv pplacer-Linux-v1.1.alpha19 /opt/pplacer
ENV PATH="/opt/pplacer:${PATH}"

##### ---- CheckM 1.2.3 ----
# Pin minimal scientific stack that CheckM expects to stay stable in SDK image.
RUN pip install --no-cache-dir \
      "numpy" \
      "matplotlib==3.1.0" \
      "pysam" \
      "scipy" \
      "dendropy" \
      "coverage" \
      "checkm-genome==1.2.3"

# Configure CheckM data root (no hard-coded site-packages path)
ENV CHECKM_DATA_PATH=/data/checkm_data
RUN mkdir -p "$CHECKM_DATA_PATH" \
 && python - <<'PY'
import os, importlib, pathlib
pkg = importlib.import_module('checkm')
cfg = pathlib.Path(pkg.__file__).parent/'DATA_CONFIG'
cfg.write_text(os.environ.get('CHECKM_DATA_PATH','/data/checkm_data')+'\n')
print('Wrote', cfg, '->', cfg.read_text().strip())
PY

# (Optional) quick smoke test
RUN checkm -h >/dev/null 2>&1 || (echo "CheckM not on PATH" && exit 1)

##### ---- App wiring (same as your current image) ----
WORKDIR /kb/module
COPY ./ /kb/module

RUN mkdir -p /kb/module/work/tmp/test_data \
 && cp -r /kb/module/test/data/* /kb/module/work/tmp/test_data/ \
 && chmod -R a+rw /kb/module \
 && make all \
 && rm -f /data/__READY__

ENTRYPOINT ["./scripts/entrypoint.sh"]
CMD []
